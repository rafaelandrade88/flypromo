# FlightWatch — variáveis de ambiente
# NUNCA preencha este arquivo com valores reais.
# Use: supabase secrets set NOME=valor
# Este arquivo serve apenas como referência de quais secrets configurar.

SERPAPI_KEY=sua_serpapi_key_aqui
ANTHROPIC_API_KEY=sua_anthropic_api_key_aqui

# ── Frontend (Vite) ─────────────────────────────────────────
# A chave abaixo é a "publishable" (anon) do Supabase: pode ser
# exposta no bundle. O app tem fallback embutido em src/lib/supabase.ts;
# defina estas variáveis apenas se quiser apontar para outro projeto.
VITE_SUPABASE_URL=
VITE_SUPABASE_KEY=
